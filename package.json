{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Y7XIFIED",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @workspace/api-server\" \"npm run dev -w @workspace/vinyl-player\"",
    "build": "npm run typecheck && npm run --workspaces --if-present build",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run --workspaces --if-present typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}